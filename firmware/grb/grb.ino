// ================= PIN CONFIG =================
void configuration() {

  mxconfig.gpio.r1 = 25;
  mxconfig.gpio.g1 = 26;
  mxconfig.gpio.b1 = 27;

  mxconfig.gpio.r2 = 14;
  mxconfig.gpio.g2 = 12;
  mxconfig.gpio.b2 = 13;

  mxconfig.gpio.a = 23;
  mxconfig.gpio.b = 19;
  mxconfig.gpio.c = 5;
  mxconfig.gpio.d = 17;

  mxconfig.gpio.clk = 16;
  mxconfig.gpio.lat = 4;
  mxconfig.gpio.oe = 15;
}

// ================= WIFI =================
void connectWiFi() {

  WiFi.begin(ssid, password);

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
  }
}

// ================= TIME =================
String getTimeString() {

  struct tm t;

  if (!getLocalTime(&t))
    return "00:00";

  char buf[6];
  strftime(buf, 6, "%H:%M", &t);

  return String(buf);
}

// ================= DRAW SCREEN =================
void drawScreen() {

  display->clearScreen();

  // GRB (32x32)
  display->drawRGBBitmap(0, 0, epd_bitmap_ets_grb, 32, 32);

  // TIME
  display->setTextSize(2);
  display->setTextColor(display->color565(255,255,255));
  display->setCursor(38,4);
  display->print(getTimeString());

  // STATUS
  display->setTextSize(1);
  display->setTextColor(display->color565(255,0,0));
  display->setCursor(38,24);
  display->print(statusText);
}

// ================= SETUP =================
void setup() {

  configuration();

  display = new MatrixPanel_I2S_DMA(mxconfig);
  display->begin();
  display->setBrightness8(180);
  display->setTextWrap(false);

  connectWiFi();

  configTime(gmtOffset_sec, daylightOffset_sec, ntpServer);

  struct tm timeinfo;
  while(!getLocalTime(&timeinfo)){
    delay(500);
  }
}

// ================= LOOP =================
void loop() {

  drawScreen();

  delay(1000);
}